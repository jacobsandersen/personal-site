---
import type { GetStaticPaths } from "astro";
import { getDateParts, parseAdhoc } from "~/util/dates";
import HFeedRenderer from "~/components/microformat/hfeed/HFeedRenderer.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getFirstStringOrBlank } from "~/util/mf2-util";
import { MicropubContent, MicropubContentLoader } from "~/lib/micropub";
import PageTitle from "~/components/PageTitle.astro";

export const getStaticPaths = (async () => {
  const posts = await MicropubContentLoader.create().hType("h-entry").sorted().load();

  const byYearMonthDay = posts.reduce((acc, post) => {
    const published = getFirstStringOrBlank(post.entry.properties, "published");
    if (!published) {
      return acc;
    }

    const { year, month, day } = getDateParts(published);
    if (!acc[year]) acc[year] = {};
    if (!acc[year][month]) acc[year][month] = {};
    if (!acc[year][month][day]) acc[year][month][day] = [];

    acc[year][month][day].push(post);

    return acc;
  }, {} as Record<string, Record<string, Record<string, MicropubContent[]>>>);

  return Object.entries(byYearMonthDay).flatMap(([year, byMonthDay]) => {
    return Object.entries(byMonthDay).flatMap(([month, byDay]) => {
      return Object.entries(byDay).map(([day, posts]) => ({
        params: { year, month, day },
        props: { posts }
      }));
    })
  });
}) satisfies GetStaticPaths;

const { year, month, day } = Astro.params;
const { posts } = Astro.props;
const { pathname } = Astro.url;

const date = new Date()
date.setFullYear(Number(year))
date.setMonth(Number(month) - 1)
date.setDate(Number(day))

const formattedMonthYear = parseAdhoc(date, 'MMMM, YYYY')
const formattedDate = parseAdhoc(date, 'MMMM DD, YYYY')

const title = `Posts from ${formattedDate}`;
---

<BaseLayout title={title}>
    <PageTitle title={title} crumbs={["Home:/", `Posts from ${year}:/${year}`, `Posts from ${formattedMonthYear}:/${year}/${month}`, `${title}:${pathname}`]} />
    <HFeedRenderer posts={posts} feedInfo={{title, url:`/${year}/${month}/${day}`, headerConfig: { level: 2, hidden: true }}} />
</BaseLayout>
