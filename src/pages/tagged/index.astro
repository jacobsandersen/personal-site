---
import PageTitle from "~/components/PageTitle.astro";
import Link from "~/components/util/Link.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { MicropubContentLoader } from "~/lib/micropub";

const categories = [
  ...new Set(
    (await MicropubContentLoader.create().load()).flatMap((post) =>
      (post.entry.properties["category"] ?? []).filter(
        (cat) => typeof cat === "string",
      ),
    ),
  ),
];
---

<BaseLayout title="Post Tags">
  <PageTitle 
    title="Post Tags" 
    subtitle="This page lists all of the tags/categories that I have ever used in making a post, and links back to those posts." 
    crumbs={["Home:/", "Post Tags:/tagged"]} />
  <ul class="tw:grid tw:grid-cols-3 tw:gap-1">
    {
      categories.map((category) => (
        <li>
          <Link href={`/tagged/${category}`}>#{category}</Link>
        </li>
      ))
    }
  </ul>
</BaseLayout>
