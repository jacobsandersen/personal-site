---
import Link from "../util/Link.astro";

const { pathname } = Astro.url;

interface NavLink {
  text: string,
  href: string,
  activeIf: (pathname: string) => boolean
}

const navLinks: NavLink[] = [
  { text: "the glade", href: "/", activeIf: (pathname) => pathname === '/' },
  { text: "the workshop", href: "/workshop", activeIf: (pathname) => pathname.startsWith("/workshop") },
  { text: "tagged posts", href: "/tagged", activeIf: (pathname) => pathname.startsWith("/tagged") }
]
---

<header class="tw:flex tw:justify-between tw:items-center tw:py-2 tw:mb-2 tw:border-b tw:border-dashed">
  <h2><Link href="/" withUnderline={false}>jacob's garden</Link></h2>
  <nav class="tw:text-xs">
    <ul class="tw:inline-flex tw:gap-x-3">
      {
        navLinks.map((link) => (
          <li class:list={{ "tw:font-bold": link.activeIf(pathname) }}>
            <Link href={link.href}>{link.text}</Link>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
