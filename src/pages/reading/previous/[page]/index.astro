---
export const prerender = false

import BookList from "~/components/ssr/BookList.astro"
import BaseLayout from "~/layouts/BaseLayout.astro"
import { getPreviousReads } from "~/lib/seer"

const { page } = Astro.params
const normalizedPage = Number.parseInt(page ?? '1')
const books = await getPreviousReads(normalizedPage)
if (!books) {
  return Astro.redirect("/reading");
}
const totalPages = books.pagination.total_pages
---

<BaseLayout title=`Previous Reads (Page ${normalizedPage}/${totalPages}) - The Library`>
  <div class="tw:flex tw:flex-col tw:gap-y-4">
    <div>
      <h1 class="tw:text-3xl">Previously Read (Page {normalizedPage} of {totalPages})</h1>
      <p class="tw:text-sm">I've already read these books. That means, I'm totally open to discuss any of these with you! I might read them again some day, but no bother. If you want to talk about them, hit me up!</p>
    </div>
    <BookList 
      books={books}
      pageBase="/reading/previous"
      cols={2}
      includeLastRead={true}
    />
  </div>
</BaseLayout>
