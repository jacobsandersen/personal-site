---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import MicroformatRenderer from "~/components/microformat/MicroformatRenderer.astro";
import { getDateParts } from "~/util/dates";
import { getFirstStringOrBlank } from "~/util/mf2-util";

export const getStaticPaths = (async () => {
  const posts = await getCollection("micropub");
  return posts.flatMap((post) => {
    const published = getFirstStringOrBlank(post.data.properties, "published");
    if (!published) return [];

    const slug = getFirstStringOrBlank(post.data.properties, "mp-slug");
    if (!slug) return [];

    const { year, month, day } = getDateParts(published);

    return [{
      params: { year, month, day, slug },
      props: { post: post.data },
    }];
  });
}) satisfies GetStaticPaths;

const { post } = Astro.props;
---

<MicroformatRenderer doc={post} />
