---
import type { GetStaticPaths } from "astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import MicroformatRenderer from "~/components/microformat/MicroformatRenderer.astro";
import { MicropubContentLoader } from "~/lib/micropub";
import { getDateParts, parseAdhoc } from "~/util/dates";
import { getFirstStringOrBlank } from "~/util/mf2-util";

export const getStaticPaths = (async () => {
  return (await MicropubContentLoader.create().hType("h-entry").sorted().load()).flatMap((post) => {
    const published = getFirstStringOrBlank(post.entry.properties, "published");
    if (!published) return [];

    const slug = getFirstStringOrBlank(post.entry.properties, "mp-slug");
    if (!slug) return [];

    const { year, month, day } = getDateParts(published);

    return [{
      params: { year, month, day, slug },
      props: { year, month, day, post: post },
    }];
  });
}) satisfies GetStaticPaths;

const { year, month, day, post } = Astro.props;
const { pathname } = Astro.url;

const date = new Date()
date.setFullYear(Number(year))
date.setMonth(Number(month) - 1)
date.setDate(Number(day))

const formattedMonth = parseAdhoc(date, 'MMMM')
---

<MicroformatRenderer doc={post} crumbs={[
    "Home:/", `${year}:/${year}`, `${formattedMonth}:/${year}/${month}`, `${day}:/${year}/${month}/${day}`, "This Post"
  ]} />
