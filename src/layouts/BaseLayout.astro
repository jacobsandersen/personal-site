---
import SiteHeader from "~/components/structure/SiteHeader.astro";
import SiteFooter from "~/components/structure/SiteFooter.astro";
import "~/styles/global.css";

interface Props {
	title?: string;
}

const { title } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="fediverse:creator" content="@simpleauthority@mastodon.social">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="pgpkey" href="/gpg.pub.txt" />
		<link rel="authorization_endpoint" href="https://indieauth.com/auth" />
		<link rel="token_endpoint" href="https://tokens.indieauth.com/token" />
		<link rel="micropub" href="https://scribble.jacobandersen.dev/micropub" />
		<slot name="additionalHead" />
		<title>{title ?? "Unnamed Page"} &ndash; Jacob Andersen</title>
	</head>
	<body class="tw:h-screen tw:px-4 tw:md:px-0 tw:md:max-w-7/9 tw:lg:max-w-6/9 tw:xl:max-w-5/9 tw:mx-auto">
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
	</body>
</html>
