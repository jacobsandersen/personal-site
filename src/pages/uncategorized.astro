---
import HFeedRenderer from "~/components/microformat/hfeed/HFeedRenderer.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { MicropubContentLoader } from "~/lib/micropub";

const posts = (await MicropubContentLoader.create().load())
  .filter(post => {
    const category = post.entry.properties['category']
    return !category || category.length === 0
  })
  .map(post => post);

const title = `Uncategorized Posts`
---

<BaseLayout title={title}>
  <HFeedRenderer
    posts={posts}
    feedInfo={{ title, url: `/uncategorized` }}
    class="tw:col-span-16"
    itemClass="tw:my-2"
  />
</BaseLayout>