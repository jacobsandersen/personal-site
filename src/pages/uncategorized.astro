---
import { getCollection } from "astro:content";
import HFeedRenderer from "~/components/microformat/hfeed/HFeedRenderer.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";

const posts = (await getCollection("micropub"))
  .filter(post => {
    const category = post.data.properties['category']
    return !category || category.length === 0
  })
  .map(post => post.data);

const title = `Uncategorized Posts`
---

<BaseLayout title={title}>
  <HFeedRenderer
    posts={posts}
    feedInfo={{ title, url: `/uncategorized` }}
    class="tw:col-span-16"
    itemClass="tw:my-2"
  />
</BaseLayout>