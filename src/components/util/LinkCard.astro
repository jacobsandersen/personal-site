---
import Link from './Link.astro';

export interface Props {
  href: string;
  class?: string;
}

const { href, class: className = "" } = Astro.props as Props
---

<Link href={href} class:list={["tw:border", "tw:p-2", "tw:rounded-sm", className]} withUnderline={false}>
  <slot name="title" />
  <slot />
</Link>